# /etc/flowplane-agent/agent.env
#
# Per-host configuration for flowplane-agent. Install with:
#   install -d -m 0755 /etc/flowplane-agent
#   install -m 0640 -o root -g flowplane-agent agent.env /etc/flowplane-agent/agent.env

# gRPC endpoint of the Flowplane control plane diagnostics service. mTLS only.
FLOWPLANE_AGENT_CP_ENDPOINT=https://flowplane-cp.example.internal:18000

# Stable identity for this dataplane. Must match the dataplane row in the CP
# (see `flowplane dataplane create`). The SPIFFE cert SAN must agree.
FLOWPLANE_AGENT_DATAPLANE_ID=prod-edge-vm-1

# SPIFFE mTLS material, delivered by your existing cert provisioning
# pipeline (SPIRE agent, cert-manager, manual rotation, etc.).
FLOWPLANE_AGENT_TLS_CERT_PATH=/var/run/spiffe/tls.crt
FLOWPLANE_AGENT_TLS_KEY_PATH=/var/run/spiffe/tls.key
FLOWPLANE_AGENT_TLS_CA_PATH=/var/run/spiffe/ca.crt

# Log level. `info` is the right default; raise to `debug` only when
# investigating a specific issue.
RUST_LOG=info
